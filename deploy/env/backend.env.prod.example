NODE_ENV=production
PORT=5000

DB_DIALECT=sqlite
DB_STORAGE=public/data/cms.sqlite
SECURITY_DB_STORAGE=public/data/security.sqlite
DB_LOGGING=false

UPLOAD_DIR=public/uploads
TEMP_DIR=temp

CORS_ORIGIN=https://notes.lifetip.top,https://cms.lifetip.top

DEFAULT_PASSWORD=replace-initial-admin-password
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_EXPIRES_IN=12h
AUTH_COOKIE_NAME=veldr_auth
AUTH_COOKIE_MAX_AGE_MS=43200000

CMS_DATA_DIR=public/data/cms
CMS_DB_FILE=db.json
CMS_SECRET_FILE=secret.json
CMS_UPLOAD_DIR=public/uploads/cms
CMS_VIEWER_PASSWORD=replace-viewer-key
CMS_EDITOR_PASSWORD=replace-editor-key
