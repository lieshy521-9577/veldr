NODE_ENV=development
PORT=5000

DB_DIALECT=sqlite
DB_STORAGE=public/data/cms.sqlite
SECURITY_DB_STORAGE=public/data/security.sqlite
DB_LOGGING=false

UPLOAD_DIR=public/uploads
TEMP_DIR=temp

CORS_ORIGIN=http://localhost:5173,http://localhost:5174

DEFAULT_PASSWORD=123456
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h
AUTH_COOKIE_NAME=veldr_auth
AUTH_COOKIE_MAX_AGE_MS=43200000

CMS_DATA_DIR=public/data/cms
CMS_DB_FILE=db.json
CMS_SECRET_FILE=secret.json
CMS_UPLOAD_DIR=public/uploads/cms
CMS_VIEWER_PASSWORD=11
CMS_EDITOR_PASSWORD=
